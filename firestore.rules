rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData(request.auth.uid).role == role;
    }

    function isAdmin() {
      return isSignedIn() && (
        hasRole('admin') || 
        request.auth.token.email == 'nadouajmi@gmail.com'
      );
    }

    // --- Collection Rules ---

    // CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn() && isOwner(resource.data.userId);
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if hasRole('admin') || hasRole('therapist');
      allow create: if isOwner(userId) && 
                      incoming().keys().hasAll(['email', 'displayName', 'role', 'createdAt']) &&
                      incoming().role == 'patient'; // Only patients can self-register
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoUrl', 'bio', 'specialty'])
                      || hasRole('admin');
    }

    // JOURNALS
    match /journals/{journalId} {
      function isValidJournal(data) {
        return data.userId is string && data.content is string && data.content.size() >= 10 && data.content.size() <= 10000;
      }

      allow read: if isSignedIn() && (isOwner(existing().userId) || hasRole('therapist') || hasRole('admin'));
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidJournal(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    // EMOTIONS
    match /emotions/{emotionId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || hasRole('therapist'));
      allow create: if isSignedIn() && isOwner(incoming().userId);
    }

    // APPOINTMENTS
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (isOwner(resource.data.patientId) || isOwner(resource.data.therapistId) || hasRole('admin'));
      allow create: if isSignedIn() && isOwner(incoming().patientId);
      allow update: if isSignedIn() && (isOwner(resource.data.patientId) || isOwner(resource.data.therapistId) || hasRole('admin'));
    }

    // RECOMMENDATIONS (Read all, write only admin)
    match /recommendations/{recId} {
      allow read: if isSignedIn();
      allow write: if hasRole('admin');
    }

    // ALERTS
    match /alerts/{alertId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || hasRole('admin'));
      allow create: if isSignedIn(); // Users can trigger alerts (e.g. crisis)
      allow update: if hasRole('admin');
    }

    // PAYMENTS
    match /payments/{paymentId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isOwner(resource.data.therapistId) || hasRole('admin'));
      allow create: if isSignedIn() && isOwner(incoming().userId);
    }
  }
}
